PORT=4173
HOST=127.0.0.1

# Default is local deterministic coaching with no external model calls.
# For stronger actual-problem coaching, use a local Ollama model:
#   AI_PROVIDER=ollama
#   AI_BASE_URL=http://localhost:11434
#   AI_MODEL=qwen2.5-coder:7b
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=qwen2.5-coder:7b
AI_CONTEXT_TOKENS=4096
AI_MAX_OUTPUT_TOKENS=2600
AI_REQUEST_TIMEOUT_MS=120000

# Advanced: point to any OpenAI-compatible /chat/completions endpoint.
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://your-provider.example/v1
# AI_API_KEY=
